# TradeMind — Environment Variables
# Copy this file to .env and fill in your actual values
# Never commit .env to git

# ── Capital ────────────────────────────────────────────────────────────────────
TOTAL_CAPITAL=3000

# ── Mode: paper or live (start with paper — always) ───────────────────────────
TRADING_MODE=paper

# ── Zerodha Kite (Phase 4 only — leave blank until then) ──────────────────────
KITE_API_KEY=
KITE_API_SECRET=
KITE_ACCESS_TOKEN=

# ── Telegram alerts ────────────────────────────────────────────────────────────
# Get token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=
# Get chat ID: https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_CHAT_ID=
